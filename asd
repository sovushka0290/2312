import os
import hashlib

def get_nomad_wallet(user_id: str):
    # Достаем секретную соль из системы (если ее нет, используем дефолтную, но лучше чтобы была)
    salt = os.getenv("WALLET_SALT", "fallback_salt_for_dev_only")
    
    # Смешиваем ID пользователя с секретной солью
    secured_string = f"{user_id}_{salt}"
    
    # Теперь хешируем защищенную строку
    wallet_seed = hashlib.sha256(secured_string.encode()).hexdigest()
    
    # ... дальше твой старый код генерации кошелька из wallet_seed ...
    return wallet_seed
