def create_campaign(fund_name: str, title: str, requirements: str, reward: int):
    conn = sqlite3.connect('protoqol.db')
    c = conn.cursor()
    c.execute('''
        INSERT INTO campaigns (fund_name, title, requirements, reward)
        VALUES (?, ?, ?, ?)
    ''', (fund_name, title, requirements, reward))
    campaign_id = c.lastrowid
    conn.commit()
    conn.close()
    return campaign_id

def get_active_campaign():
    """Для MVP на хакатоне берем последнюю активную кампанию"""
    conn = sqlite3.connect('protoqol.db')
    c = conn.cursor()
    c.execute('SELECT id, fund_name, title, requirements, reward FROM campaigns WHERE is_active = 1 ORDER BY id DESC LIMIT 1')
    row = c.fetchone()
    conn.close()
    if row:
        return {"id": row[0], "fund_name": row[1], "title": row[2], "requirements": row[3], "reward": row[4]}
    return None
