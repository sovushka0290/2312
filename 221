// Конфиг для синхронизации
const API_URL = "https://твой-бэкенд.pro/api"; 

const useSyncData = () => {
  const [data, setData] = useState(null);

  const sync = async () => {
    const initData = window.Telegram.WebApp.initData;
    const user = window.Telegram.WebApp.initDataUnsafe.user;

    // Стучимся к твоему Python-серверу
    const res = await fetch(`${API_URL}/user-status?id=${user.id}`, {
      headers: { 'Authorization': initData }
    });
    
    const sheetData = await res.json();
    
    // Синхронизируем локальное состояние
    setData({
      name: user.first_name,
      avatar: user.photo_url,
      role: sheetData.role,
      sbt: sheetData.sbt_balance,
      lang: sheetData.lang
    });
    
    // Меняем язык интерфейса на лету
    i18n.changeLanguage(sheetData.lang);
  };

  return { data, sync };
};
